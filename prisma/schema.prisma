generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum MessageActor {
  USER
  ASSISTANT
  SYSTEM
}

enum TranslationDirection {
  SATOORI_TO_SEOUL @map("satoori-to-seoul")
  SEOUL_TO_SATOORI @map("seoul-to-satoori")
}

model AnonymousSession {
  id           String       @id @default(cuid())
  sessionToken String       @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  lastSeenAt   DateTime     @default(now())
  threads      ChatThread[]

  @@index([lastSeenAt])
}

model ChatThread {
  id          String           @id @default(cuid())
  sessionId   String
  threadToken String           @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  archivedAt  DateTime?
  session     AnonymousSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]

  @@index([sessionId, createdAt])
}

model MessageType {
  id          Int           @id
  code        String        @unique
  description String?
  messages    ChatMessage[]
}

model ChatMessage {
  id                 String                   @id @default(cuid())
  threadId           String
  typeId             Int
  actor              MessageActor
  direction          TranslationDirection?
  inReplyToMessageId String?
  createdAt          DateTime                 @default(now())
  thread             ChatThread               @relation(fields: [threadId], references: [id], onDelete: Cascade)
  type               MessageType              @relation(fields: [typeId], references: [id], onDelete: Restrict)
  inReplyToMessage   ChatMessage?             @relation("MessageReplies", fields: [inReplyToMessageId], references: [id], onDelete: SetNull)
  replies            ChatMessage[]            @relation("MessageReplies")
  userContent        UserMessageContent?
  assistantContent   AssistantMessageContent?
  errorContent       ErrorMessageContent?

  @@index([threadId, createdAt])
  @@index([typeId, createdAt])
  @@index([inReplyToMessageId])
}

model UserMessageContent {
  messageId String      @id
  text      String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model AssistantMessageContent {
  messageId      String      @id
  responseType   String?
  translatedText String
  realMeaning    String?
  emotionLabel   String?
  responseTip    String?
  message        ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model ErrorMessageContent {
  messageId    String      @id
  errorMessage String
  message      ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
}
